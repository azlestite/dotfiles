Include ~/.ssh/ssh_config

LogLevel VERBOSE

#### Connection ####
Compression yes
ConnectionAttempts 3
ServerAliveInterval 60
ServerAliveCountMax 3

# Exit on forwarding failure
# Use when maintaining a tunnel as an alternative to a VPN
# ExitOnForwardFailure yes

#### ControlMaster ####
# When you connect repeatedly or establish multiple connections,
# existing connections are reused, which speeds up the SSH startup process.
# If you frequently put your computer to sleep or
# move your laptop around to different network locations,
# set ControlPersist to a shorter interval, ranging from 10 seconds(10) to a few minutes(1m).
# For a stationary device with a wired connection that does not enter sleep mode,
# even high values such as 1 to 2 hours(1h～2h) are possible
# ControlMaster auto
# ControlPersist 10 # For mobile devices
# ControlPath ~/.ssh/%C

#### Security ####
# Ciphers aes256-gcm@openssh.com,chacha20-poly1305@openssh.com,aes128-gcm@openssh.com,aes256-ctr,aes192-ctr,aes128-ctr

# Key Exchange Algorithm
# KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org,ecdh-sha2-nistp521,ecdh-sha2-nistp384,ecdh-sha2-nistp256,diffie-hellman-group18-sha512,diffie-hellman-group16-sha512,diffie-hellman-group14-sha256,diffie-hellman-group-exchange-sha256

# Keyed hash algorithms
# Macs umac-128-etm@openssh.com,hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com,umac-128@openssh.com,hmac-sha2-512,hmac-sha2-256,umac-64-etm@openssh.com,umac-64@openssh.com,hmac-sha1

# Verify host keys in modern order
HostKeyAlgorithms ssh-ed25519-cert-v01@openssh.com,sk-ssh-ed25519-cert-v01@openssh.com,ssh-ed25519,sk-ssh-ed25519@openssh.com,ecdsa-sha2-nistp521-cert-v01@openssh.com,ecdsa-sha2-nistp384-cert-v01@openssh.com,ecdsa-sha2-nistp256-cert-v01@openssh.com,sk-ecdsa-sha2-nistp256-cert-v01@openssh.com,sk-ecdsa-sha2-nistp256@openssh.com,ecdsa-sha2-nistp521,ecdsa-sha2-nistp384,ecdsa-sha2-nistp256,ssh-rsa-cert-v01@openssh.com,rsa-sha2-512,rsa-sha2-256,ssh-rsa

# Key generation frequency
RekeyLimit default none

# SSH Agent Forwarding
# ForwardAgent yes

# Visually display the host fingerprint
# VisualHostKey yes
